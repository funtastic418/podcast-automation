generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String?   @unique
  name      String?
  settings  Settings?
  episodes  Episode[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Settings {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // AI Provider
  aiProvider      String  @default("openai") // "openai" | "anthropic"
  openaiApiKey    String? // encrypted
  anthropicApiKey String? // encrypted
  aiModel         String  @default("gpt-4o")

  // ElevenLabs
  elevenlabsApiKey     String? // encrypted
  elevenlabsVoiceId    String?
  elevenlabsModelId    String  @default("eleven_multilingual_v2")
  elevenlabsStability  Float   @default(0.5)
  elevenlabsSimilarity Float   @default(0.75)

  // Podcast info (for RSS feed)
  podcastName        String?
  podcastDescription String?
  podcastAuthor      String?
  podcastCoverUrl    String? // URL to cover image (3000x3000)
  podcastCategory    String  @default("Technology")
  podcastLanguage    String  @default("en-us")
  podcastExplicit    Boolean @default(false)

  // Script generation
  defaultPromptTemplate String? // custom system prompt for AI
  targetScriptLength    Int     @default(1500) // word count target

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Episode {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content
  topic         String
  title         String?
  slug          String?   @unique
  episodeNumber Int?
  script        String?
  summary       String?

  // Audio
  duration      Int?    // seconds
  audioUrl      String? // Vercel Blob URL
  audioFileSize Int?    // bytes

  // Pipeline status
  // pending | generating_script | generating_audio | uploading_audio | published | failed
  status       String  @default("pending")
  errorMessage String?
  errorStep    String?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  pipelineLogs PipelineLog[]

  @@index([userId])
  @@index([status])
}

model PipelineLog {
  id        String @id @default(cuid())
  episodeId String

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  step       String // generate_script, generate_audio, upload_audio
  status     String // started, completed, failed
  message    String?
  durationMs Int?
  metadata   String? // JSON blob

  createdAt DateTime @default(now())

  @@index([episodeId])
}
